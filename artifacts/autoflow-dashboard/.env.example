# Copy this file to .env and fill in your values

# Production (Vercel): set to your full Render backend /api URL
# e.g. https://autoflow-api.onrender.com/api
VITE_API_BASE_URL=

# Dev server port
PORT=5173
BASE_PATH=/

# Backend proxy target for local dev (localhost only)
API_BASE_URL=http://localhost:3000
